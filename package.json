{
  "name": "doomplanner",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.23.0",
  "type": "module",
  "main": "electron/main.cjs",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-production-calendar.mjs && node scripts/generate-icon.mjs && tsc -b && vite build && node scripts/strip-icon-sources.mjs",
    "icons": "node scripts/generate-icon.mjs",
    "calendar": "node scripts/build-production-calendar.mjs",
    "test": "node scripts/build-production-calendar.mjs && npx --yes tsx scripts/verify-daily-meetings.mjs && npx --yes tsx scripts/verify-attachments.mjs && npx --yes tsx scripts/verify-month-calendar.mjs && npx --yes tsx scripts/verify-holiday-labels.mjs && npx --yes tsx scripts/verify-projects.mjs",
    "test:daily": "npx --yes tsx scripts/verify-daily-meetings.mjs",
    "test:attachments": "npx --yes tsx scripts/verify-attachments.mjs",
    "test:month": "npx --yes tsx scripts/verify-month-calendar.mjs",
    "test:holidays": "npx --yes tsx scripts/verify-holiday-labels.mjs",
    "test:projects": "npx --yes tsx scripts/verify-projects.mjs",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "node scripts/electron-build.mjs",
    "clean:dist": "node scripts/clean-dist.mjs"
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uuid": "^14.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.7.0",
    "oxlint": "^1.71.0",
    "sharp": "^0.35.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.doomplanner.desktop",
    "productName": "RuneBoard",
    "icon": "resources/icon.png",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "build/**/*",
      "!build/**/*-source.png",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "ru",
        "en"
      ]
    }
  }
}
